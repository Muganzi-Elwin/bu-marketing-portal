<!DOCTYPE html>
<html>
<head>
  <title>Submission Received</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f7f9fc;
    }

    .success-container {
      max-width: 760px;
    }

    .success-card {
      border: 0;
      border-radius: 1rem;
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<%
  let message = "Your submission has been received successfully.";
  let secondaryLink = "/programs";
  let secondaryText = "View Programs";

  if (type === "work") {
    message = "Your work program application has been submitted successfully.";
  }

  if (type === "financial-support") {
    message = "Your financial support application has been submitted successfully.";
    secondaryLink = "/financial-support";
    secondaryText = "View Financial Support";
  }
%>

<main class="container success-container py-5">
  <div class="card success-card shadow-sm text-center">
    <div class="card-body p-4 p-md-5">
      <div class="alert alert-success border-0 mb-4">
        <h1 class="h3 fw-bold mb-2">Success</h1>
        <p class="mb-0"><%= message %></p>
      </div>

      <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
        <a href="/" class="btn btn-primary px-4">Return Home</a>
        <a href="<%= secondaryLink %>" class="btn btn-outline-primary px-4"><%= secondaryText %></a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
