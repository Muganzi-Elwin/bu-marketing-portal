<!DOCTYPE html>
<html>
<head>
  <title>Feedback Form</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f7f9fc;
    }

    .feedback-container {
      max-width: 820px;
    }

    .feedback-card {
      border: 0;
      border-radius: 1rem;
    }

    .rating-button {
      cursor: pointer;
      border: 1px solid #d8e2ef;
      border-radius: 0.75rem;
      background: #fff;
      transition: all 0.2s ease;
    }

    .rating-button.selected {
      background: #0b5ed7;
      border-color: #0b5ed7;
      color: #fff;
      box-shadow: 0 0.5rem 1rem rgba(11, 94, 215, 0.18);
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<main class="container feedback-container py-5">
  <div class="text-center mb-4">
    <h1 class="fw-bold mb-2">Feedback Form</h1>
    <p class="text-muted fs-5 mb-0">Help Us Improve Our Services</p>
  </div>

  <% if (source === "admission") { %>
    <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4">
      Thank you for your admission application. Please provide feedback.
    </div>
  <% } %>

  <div class="alert alert-info border-0 shadow-sm rounded-3 mb-4">
    <p class="fw-semibold mb-2">Your submission has been received successfully!</p>

    <!-- <ul class="mb-0">
      <li>Full Admission</li>
      <li>Quick Apply</li>
      <li>Scholarship</li>
      <li>Bursary</li>
      <li>Work Program</li>
    </ul> -->
    
  </div>

  <div class="card feedback-card shadow-sm">
    <div class="card-body p-4 p-md-5">
      <form action="/feedback" method="POST">
        <div class="mb-4">
          <p class="form-label fw-semibold mb-3">How did you hear about Bugema University?</p>

          <div class="row g-3">
            <div class="col-12 col-sm-6">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="source" id="sourceSocial" value="Social Media" required>
                <label class="form-check-label" for="sourceSocial">Social Media</label>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="source" id="sourceVisit" value="School Visit" required>
                <label class="form-check-label" for="sourceVisit">School Visit</label>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="source" id="sourceRadio" value="Radio" required>
                <label class="form-check-label" for="sourceRadio">Radio</label>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="source" id="sourceFriend" value="Friend" required>
                <label class="form-check-label" for="sourceFriend">Friend</label>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="source" id="sourceWebsite" value="Website Search" required>
                <label class="form-check-label" for="sourceWebsite">Website Search</label>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="source" id="sourceOther" value="Other" required>
                <label class="form-check-label" for="sourceOther">Other</label>
              </div>
            </div>
          </div>
        </div>

        <div class="mb-4">
          <p class="form-label fw-semibold mb-2">Rating</p>
          <div class="d-flex justify-content-between text-muted small mb-2">
            <span>Poor</span>
            <span>Excellent</span>
          </div>

          <div class="row g-2">
            <% [1, 2, 3, 4, 5].forEach((rating) => { %>
              <div class="col">
                <button type="button" class="rating-button w-100 text-center fw-semibold py-3" data-rating="<%= rating %>"><%= rating %></button>
              </div>
            <% }) %>
          </div>
          <input type="hidden" id="rating" name="rating" required>
        </div>

        <div class="mb-4">
          <label for="comment" class="form-label fw-semibold">Comment</label>
          <textarea id="comment" name="comment" class="form-control" rows="5" placeholder="Share any additional thoughts..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100">Submit Feedback</button>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const ratingInput = document.getElementById("rating");
  const ratingButtons = document.querySelectorAll("[data-rating]");

  ratingButtons.forEach((button) => {
    button.addEventListener("click", () => {
      ratingInput.value = button.dataset.rating;

      ratingButtons.forEach((ratingButton) => {
        ratingButton.classList.remove("selected");
      });

      button.classList.add("selected");
    });
  });
</script>
</body>
</html>
