<!DOCTYPE html>
<html>
<head>
  <title>B-U Marketing Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f7f9fc;
    }

    .page-container {
      max-width: 1140px;
    }

    .hero-section {
      background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
      border-radius: 1.25rem;
    }

    .hero-visual {
      min-height: 12rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #dbeafe 0%, #f8fafc 100%);
      color: #64748b;
      border: 1px solid #d8e2ef;
      border-radius: 1rem;
    }

    .program-visual {
      min-height: 8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #edf4ff;
      color: #64748b;
      border-radius: 0.85rem;
    }

    .program-card {
      border: 0;
      border-radius: 1rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .program-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.12);
    }

    .section-title {
      color: #102a43;
    }

    .cta-section {
      background: #eaf2ff;
      border-radius: 1.25rem;
    }

    .btn-primary {
      background-color: #0b5ed7;
      border-color: #0b5ed7;
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<main class="container page-container py-5">
  <% if (success === "feedback") { %>
    <div id="successAlert" class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 mb-4" role="alert">
      Thank you! Your feedback has been submitted successfully.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <section class="hero-section text-center p-4 p-md-5 mb-5 shadow-sm">
    <div class="mx-auto" style="max-width: 760px;">
      <div class="hero-visual mb-4 shadow-sm">
        [HERO IMAGE]
      </div>

      <h1 class="display-4 fw-bold mb-3">Apply to Bugema University</h1>
      <p class="fs-5 text-muted mb-4">Start your journey to excellence.</p>

      <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
        <a href="/programs" class="btn btn-outline-primary btn-lg px-4">Explore Programs</a>
        <a href="/admission" class="btn btn-primary btn-lg px-4">Apply Now</a>
      </div>
    </div>
  </section>

  <section class="mb-5">
    <h2 class="section-title fw-bold pb-2 mb-4">Featured Programs</h2>

    <div class="row g-4">
      <% (featuredPrograms || []).forEach(program => { %>
        <div class="col-12 col-md-6">
          <div class="card program-card p-3 h-100 shadow-sm">
            <div class="program-visual mb-3">[PROGRAM IMAGE]</div>
            <div class="card-body p-2">
              <h3 class="fs-4 fw-bold mb-2"><%= program.name %></h3>
              <p class="text-muted small mb-4"><%= program.school %></p>
              <a href="/programs/<%= program._id %>" class="btn btn-outline-primary w-100">View Details</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="cta-section text-center p-4 p-md-5 shadow-sm">
    <h2 class="fs-3 fw-bold mb-3">Ready to Start Your Application?</h2>
    <p class="text-muted mb-4">Begin your application today and secure your future.</p>
    <a href="/admission" class="btn btn-primary btn-lg px-5">Apply Now</a>
  </section>
</main>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const successAlert = document.getElementById("successAlert");

  if (successAlert) {
    setTimeout(() => {
      const alert = bootstrap.Alert.getOrCreateInstance(successAlert);
      alert.close();
    }, 5000);
  }
</script>
</body>
</html>
