<!DOCTYPE html>
<html>
<head>
  <title>Admin Applications</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body { background: #eef2f6; color: #263238; font-family: Arial, Helvetica, sans-serif; }
    .admin-layout { min-height: 100vh; display: flex; }
    .admin-sidebar { width: 280px; min-height: 100vh; background: linear-gradient(180deg, #003366 0%, #00264d 100%); color: #fff; padding: 1.5rem; display: flex; flex-direction: column; box-shadow: 0.5rem 0 1.5rem rgba(15, 23, 42, 0.08); }
    .admin-sidebar-header { border-bottom: 1px solid rgba(255, 255, 255, 0.16); padding-bottom: 1rem; margin-bottom: 1.25rem; }
    .admin-nav { display: grid; gap: 0.45rem; }
    .admin-nav-link { color: #fff; text-decoration: none; display: block; padding: 0.8rem 0.95rem; border-radius: 0.75rem; font-weight: 600; transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease; }
    .admin-nav-link:hover { background: rgba(255, 255, 255, 0.12); color: #ffcc00; transform: translateX(2px); }
    .admin-nav-link.active { background: #ffcc00; color: #003366; }
    .admin-sidebar-footer { margin-top: auto; padding-top: 1.25rem; border-top: 1px solid rgba(255, 255, 255, 0.16); }
    .admin-back-link { background: rgba(255, 255, 255, 0.1); }
    .admin-main { flex: 1; padding: 2rem; }
    .data-card { border: 0; border-radius: 1rem; box-shadow: 0 0.5rem 1.25rem rgba(15, 23, 42, 0.08); overflow: hidden; }
    .table { margin-bottom: 0; }
    .table thead th { background: #f8fafc; color: #334155; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.02em; }
    .status-badge { border-radius: 999px; padding: 0.35rem 0.7rem; font-weight: 700; font-size: 0.8rem; }
    .status-pending { background: #fff7df; color: #946200; }
    .status-approved { background: #e8f7ee; color: #146c43; }
    .status-default { background: #eef2f6; color: #475569; }
    .document-links { display: flex; flex-wrap: wrap; gap: 0.4rem; min-width: 130px; }
    .document-link { white-space: nowrap; }
    @media (max-width: 991.98px) { .admin-layout { flex-direction: column; } .admin-sidebar { width: 100%; min-height: auto; } .admin-main { padding: 1.25rem; } }
  </style>
</head>
<body>
  <%
    const formatDate = (date) => date ? new Date(date).toLocaleDateString("en-UG", {
      year: "numeric",
      month: "short",
      day: "numeric"
    }) : "N/A";

    const statusClass = (status) => {
      if (status === "Pending") return "status-pending";
      if (status === "Approved") return "status-approved";
      return "status-default";
    };

    const getDocumentPaths = (application) => {
      const paths = [];

      if (Array.isArray(application.documentPaths)) {
        paths.push(...application.documentPaths);
      }

      if (application.documentPath) {
        paths.push(application.documentPath);
      }

      if (Array.isArray(application.documents)) {
        paths.push(...application.documents);
      }

      return [...new Set(paths.filter(Boolean))];
    };

    const documentHref = (path) => {
      const cleanPath = String(path).replace(/\\/g, "/");
      return cleanPath.startsWith("/") ? cleanPath : `/${cleanPath}`;
    };

  %>

  <div class="admin-layout">
    <%- include('../partials/adminSidebar', { activeAdminPage: 'applications' }) %>

    <main class="admin-main">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
          <h1 class="fw-bold mb-1">Applications</h1>
          <p class="text-muted mb-0">Review submitted admissions, quick applies, financial support, and work applications.</p>
        </div>
      </div>

      <% if (typeof errorMessage !== "undefined") { %>
        <div class="alert alert-danger shadow-sm rounded-3 mb-4"><%= errorMessage %></div>
      <% } %>

      <section class="card data-card mb-4">
        <div class="card-body p-4 border-bottom">
          <h2 class="h4 fw-bold mb-0">Full Admissions</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Name</th>
                <th>Contact/Email</th>
                <th>Program</th>
                <th>Documents</th>
                <th>Status</th>
                <th>Date Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% if ((admissions || []).length === 0) { %>
                <tr><td colspan="6" class="text-muted text-center py-4">No full admission applications yet.</td></tr>
              <% } %>
              <% (admissions || []).forEach((application) => { %>
                <tr>
                  <td class="fw-semibold"><%= application.fullName %></td>
                  <td><%= application.email %><br><span class="text-muted small"><%= application.phone %></span></td>
                  <td><%= application.selectedProgram || "N/A" %></td>
                  <td>
                    <div class="document-links">
                      <% const documents = getDocumentPaths(application); %>
                      <% if (documents.length === 0) { %>
                        <span class="text-muted small">No documents uploaded</span>
                      <% } %>
                      <% documents.forEach((path, index) => { %>
                        <a href="<%= documentHref(path) %>" class="btn btn-sm btn-outline-primary document-link" target="_blank" rel="noopener">Document <%= index + 1 %></a>
                      <% }) %>
                    </div>
                  </td>
                  <td><span class="status-badge status-default">Submitted</span></td>
                  <td><%= formatDate(application.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card data-card mb-4">
        <div class="card-body p-4 border-bottom">
          <h2 class="h4 fw-bold mb-0">Quick Applies</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Name</th>
                <th>Contact/Email</th>
                <th>Program</th>
                <th>Status</th>
                <th>Date Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% if ((quickApplies || []).length === 0) { %>
                <tr><td colspan="5" class="text-muted text-center py-4">No quick apply submissions yet.</td></tr>
              <% } %>
              <% (quickApplies || []).forEach((application) => { %>
                <tr>
                  <td class="fw-semibold"><%= application.fullName %></td>
                  <td><%= application.email %><br><span class="text-muted small"><%= application.phone %></span></td>
                  <td><%= application.program || "N/A" %></td>
                  <td><span class="status-badge status-default">Submitted</span></td>
                  <td><%= formatDate(application.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card data-card mb-4">
        <div class="card-body p-4 border-bottom">
          <h2 class="h4 fw-bold mb-0">Scholarships</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Name</th>
                <th>Contact/Email</th>
                <th>Type</th>
                <th>Documents</th>
                <th>Status</th>
                <th>Date Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% if ((scholarships || []).length === 0) { %>
                <tr><td colspan="6" class="text-muted text-center py-4">No scholarship applications yet.</td></tr>
              <% } %>
              <% (scholarships || []).forEach((application) => { %>
                <tr>
                  <td class="fw-semibold"><%= application.fullName %></td>
                  <td><%= application.contact || "N/A" %></td>
                  <td><%= application.type || "N/A" %></td>
                  <td>
                    <div class="document-links">
                      <% const documents = getDocumentPaths(application); %>
                      <% if (documents.length === 0) { %>
                        <span class="text-muted small">No documents uploaded</span>
                      <% } %>
                      <% documents.forEach((path, index) => { %>
                        <a href="<%= documentHref(path) %>" class="btn btn-sm btn-outline-primary document-link" target="_blank" rel="noopener">Document <%= index + 1 %></a>
                      <% }) %>
                    </div>
                  </td>
                  <td><span class="status-badge <%= statusClass(application.status) %>"><%= application.status || "Submitted" %></span></td>
                  <td><%= formatDate(application.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card data-card mb-4">
        <div class="card-body p-4 border-bottom">
          <h2 class="h4 fw-bold mb-0">Bursaries</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Name</th>
                <th>Contact/Email</th>
                <th>Type</th>
                <th>Documents</th>
                <th>Status</th>
                <th>Date Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% if ((bursaries || []).length === 0) { %>
                <tr><td colspan="6" class="text-muted text-center py-4">No bursary applications yet.</td></tr>
              <% } %>
              <% (bursaries || []).forEach((application) => { %>
                <tr>
                  <td class="fw-semibold"><%= application.fullName %></td>
                  <td><%= application.contact || "N/A" %></td>
                  <td><%= application.type || "N/A" %></td>
                  <td>
                    <div class="document-links">
                      <% const documents = getDocumentPaths(application); %>
                      <% if (documents.length === 0) { %>
                        <span class="text-muted small">No documents uploaded</span>
                      <% } %>
                      <% documents.forEach((path, index) => { %>
                        <a href="<%= documentHref(path) %>" class="btn btn-sm btn-outline-primary document-link" target="_blank" rel="noopener">Document <%= index + 1 %></a>
                      <% }) %>
                    </div>
                  </td>
                  <td><span class="status-badge <%= statusClass(application.status) %>"><%= application.status || "Submitted" %></span></td>
                  <td><%= formatDate(application.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card data-card">
        <div class="card-body p-4 border-bottom">
          <h2 class="h4 fw-bold mb-0">Work Program Applications</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Name</th>
                <th>Contact/Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Date Submitted</th>
              </tr>
            </thead>
            <tbody>
              <% if ((workApplications || []).length === 0) { %>
                <tr><td colspan="5" class="text-muted text-center py-4">No work program applications yet.</td></tr>
              <% } %>
              <% (workApplications || []).forEach((application) => { %>
                <tr>
                  <td class="fw-semibold"><%= application.fullName %></td>
                  <td><%= application.contact || "N/A" %></td>
                  <td><%= application.selectedRole || "N/A" %></td>
                  <td><span class="status-badge <%= statusClass(application.status) %>"><%= application.status || "Submitted" %></span></td>
                  <td><%= formatDate(application.createdAt) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
