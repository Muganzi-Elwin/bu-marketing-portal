<!DOCTYPE html>
<html>
<head>
  <title>Admin Analytics</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body { background: #eef2f6; color: #263238; font-family: Arial, Helvetica, sans-serif; }
    .admin-layout { min-height: 100vh; display: flex; }
    .admin-sidebar { width: 280px; min-height: 100vh; background: linear-gradient(180deg, #003366 0%, #00264d 100%); color: #fff; padding: 1.5rem; display: flex; flex-direction: column; box-shadow: 0.5rem 0 1.5rem rgba(15, 23, 42, 0.08); }
    .admin-sidebar-header { border-bottom: 1px solid rgba(255, 255, 255, 0.16); padding-bottom: 1rem; margin-bottom: 1.25rem; }
    .admin-nav { display: grid; gap: 0.45rem; }
    .admin-nav-link { color: #fff; text-decoration: none; display: block; padding: 0.8rem 0.95rem; border-radius: 0.75rem; font-weight: 600; transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease; }
    .admin-nav-link:hover { background: rgba(255, 255, 255, 0.12); color: #ffcc00; transform: translateX(2px); }
    .admin-nav-link.active { background: #ffcc00; color: #003366; }
    .admin-sidebar-footer { margin-top: auto; padding-top: 1.25rem; border-top: 1px solid rgba(255, 255, 255, 0.16); }
    .admin-back-link { background: rgba(255, 255, 255, 0.1); }
    .admin-main { flex: 1; padding: 2rem; }
    .summary-card, .analytics-card { border: 0; border-radius: 1rem; box-shadow: 0 0.5rem 1.25rem rgba(15, 23, 42, 0.08); }
    .summary-label { color: #607080; font-weight: 600; }
    .summary-value { color: #003366; font-size: 2rem; font-weight: 800; }
    .source-row { padding: 1rem 0; border-bottom: 1px solid #e2e8f0; }
    .source-row:last-child { border-bottom: 0; }
    .progress { height: 0.7rem; background: #edf2f7; }
    .progress-bar { background: linear-gradient(135deg, #003366, #0055aa); }
    @media (max-width: 991.98px) { .admin-layout { flex-direction: column; } .admin-sidebar { width: 100%; min-height: auto; } .admin-main { padding: 1.25rem; } }
  </style>
</head>
<body>
  <% const analyticsData = typeof analytics !== "undefined" ? analytics : { totalFeedback: 0, averageRating: 0, topMarketingSource: "No data", sourceCounts: [] }; %>

  <div class="admin-layout">
    <%- include('../partials/adminSidebar', { activeAdminPage: 'analytics' }) %>

    <main class="admin-main">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
          <h1 class="fw-bold mb-1">Marketing Analytics</h1>
          <p class="text-muted mb-0">Track feedback sources and marketing channel performance.</p>
        </div>
      </div>

      <% if (typeof errorMessage !== "undefined") { %>
        <div class="alert alert-danger shadow-sm rounded-3 mb-4"><%= errorMessage %></div>
      <% } %>

      <div class="row g-4 mb-4">
        <div class="col-12 col-md-4">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Total Feedback</p>
              <div class="summary-value"><%= analyticsData.totalFeedback || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-4">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Average Rating</p>
              <div class="summary-value"><%= analyticsData.averageRating || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-4">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Top Marketing Source</p>
              <div class="summary-value fs-4"><%= analyticsData.topMarketingSource || "No data" %></div>
            </div>
          </section>
        </div>
      </div>

      <section class="card analytics-card">
        <div class="card-body p-4">
          <h2 class="h4 fw-bold mb-4">Marketing Source Counts</h2>

          <% if ((analyticsData.sourceCounts || []).length === 0) { %>
            <div class="alert alert-light border mb-0">No feedback source data available yet.</div>
          <% } %>

          <% (analyticsData.sourceCounts || []).forEach((item) => { %>
            <div class="source-row">
              <div class="d-flex justify-content-between gap-3 mb-2">
                <span class="fw-semibold"><%= item.source %></span>
                <span class="text-muted"><%= item.count %> responses</span>
              </div>
              <div class="progress" role="progressbar" aria-label="<%= item.source %>" aria-valuenow="<%= item.percentage %>" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: <%= item.percentage %>%"></div>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
