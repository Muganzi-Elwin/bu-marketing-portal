<!DOCTYPE html>
<html>
<head>
  <title>Admission Form</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

  <style>
    .form-container {
      max-width: 850px;
      margin: auto;
    }

    .section-title {
      border-bottom: 2px solid #000;
      padding-bottom: 5px;
      margin-top: 30px;
      margin-bottom: 20px;
    }

    .required::after {
      content: " *";
      color: red;
    }

    .upload-box {
      border: 2px dashed #000;
      padding: 30px;
      text-align: center;
      background: #f8f9fa;
    }
  </style>
</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container mt-5">
  <div class="card shadow p-4 form-container">

    <% const admissionPrograms = typeof programs !== "undefined" ? programs : []; %>
    <% const admissionOldInput = typeof oldInput !== "undefined" ? oldInput : {}; %>
    <% const currentProgram = admissionOldInput.selectedProgram || (typeof selectedProgram !== "undefined" ? selectedProgram : ""); %>

    <% if (typeof errorMessage !== "undefined") { %>
      <div class="alert alert-danger"><%= errorMessage %></div>
    <% } %>

    <% if (typeof errors !== "undefined" && errors.length > 0) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% errors.forEach((error) => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <h2 class="text-center mb-4">Full Admission Form</h2>

    <form action="/admission" method="POST" id="admissionForm" enctype="multipart/form-data" novalidate>

      <!-- PERSONAL INFO -->
      <h5 class="section-title">Personal Information</h5>

      <div class="mb-3">
        <label class="required">Full Name</label>
        <input type="text" name="fullName" class="form-control" placeholder="Enter your full name" value="<%= admissionOldInput.fullName || '' %>" maxlength="80" required>
        <div class="form-text">Use your full legal name, 2 to 80 characters.</div>
      </div>

      <div class="mb-3">
        <label class="required">Date of Birth</label>
        <input type="date" name="dob" class="form-control" value="<%= admissionOldInput.dob || '' %>" required>
      </div>

      <div class="mb-3">
        <label class="required">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="example@gmail.com" value="<%= admissionOldInput.email || '' %>" maxlength="120" required>
      </div>

      <div class="mb-3">
        <label class="required">Phone Number</label>
        <div class="input-group">
          <select class="form-select" id="countryCode"></select>
          <input type="text" name="phone" class="form-control" placeholder="e.g. +256 701 234 567" value="<%= admissionOldInput.phone || '' %>" maxlength="120" required>
        </div>
        <div class="form-text">Use digits, spaces, +, or hyphens.</div>
      </div>

      <div class="mb-3">
        <label class="required">Residential Address</label>
        <textarea name="address" class="form-control" rows="2" placeholder="e.g. Kampala, Uganda" maxlength="180" required><%= admissionOldInput.address || '' %></textarea>
      </div>

      <!-- ACADEMIC -->
      <h5 class="section-title">Academic Background</h5>

      <div class="mb-3">
        <label class="required">Previous School</label>
        <input type="text" name="previousSchool" class="form-control" placeholder="Name of your previous school" value="<%= admissionOldInput.previousSchool || '' %>" maxlength="120" required>
      </div>

      <div class="mb-3">
        <label class="required">Academic History</label>
        <textarea name="academicHistory" class="form-control" rows="3" placeholder="Briefly describe your academic background" maxlength="1000" required><%= admissionOldInput.academicHistory || '' %></textarea>
        <div class="form-text">Maximum 1000 characters.</div>
      </div>

      <!-- DOCUMENT UPLOAD -->
      <h5 class="section-title">Documents Upload</h5>

      <div class="mb-3">
        <label class="required">Upload Required Documents</label>

        <div class="upload-box">
          <input type="file" name="documents" class="form-control mb-2" multiple required>
          <small>
            Upload academic transcripts, certificates, and identification documents
          </small>
        </div>
      </div>

      <!-- PROGRAM -->
      <h5 class="section-title">Program Selection</h5>

      <div class="mb-3">
        <label class="required">Select Program</label>
        <select name="selectedProgram" class="form-select" id="programSelect" required>
          <option value="">-- Select Program --</option>
          <% admissionPrograms.forEach((program) => { %>
            <option value="<%= program.name %>" <%= currentProgram === program.name ? "selected" : "" %>><%= program.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label class="required">Preferred Intake</label>
        <select name="intake" class="form-select" required>
          <option value="">-- Select Intake --</option>
          <option <%= admissionOldInput.intake === "January" ? "selected" : "" %>>January</option>
          <option <%= admissionOldInput.intake === "May" ? "selected" : "" %>>May</option>
          <option <%= admissionOldInput.intake === "August" ? "selected" : "" %>>August</option>
        </select>
      </div>

      <!-- SUBMIT -->
      <button type="submit" class="btn btn-primary w-100 mt-3">
        Submit Application
      </button>

    </form>

  </div>
</div>

<%- include('partials/footer') %>
<script src="/js/form.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
<script>
  new TomSelect("#countryCode", {
    create: false,
    sortField: { field: "text", direction: "asc" },
    placeholder: "Search country code..."
  });
</script>

</body>
</html>
