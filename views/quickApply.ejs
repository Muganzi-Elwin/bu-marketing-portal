<!DOCTYPE html>
<html>
<head>
  <title>Quick Apply Form</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f7f9fc;
    }

    .quick-apply-container {
      max-width: 760px;
    }

    .form-card {
      border: 0;
      border-radius: 1rem;
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<main class="container quick-apply-container py-5">
  <%
    const quickApplyOldInput = typeof oldInput !== "undefined" ? oldInput : {};
    const quickApplySelectedProgram = quickApplyOldInput.program || selectedProgram || "";
  %>

  <div class="text-center mb-4">
    <h1 class="fw-bold mb-2">Quick Apply Form</h1>
    <p class="text-muted fs-5 mb-0">Express Your Interest - Simple Marketing Form</p>
  </div>

  <div class="alert alert-info border-0 shadow-sm rounded-3 mb-4">
    This is a simple interest form. For full admission, complete the Full Admission Form.
  </div>

  <% if (typeof errorMessage !== "undefined") { %>
    <div class="alert alert-danger shadow-sm rounded-3"><%= errorMessage %></div>
  <% } %>

  <% if (typeof errors !== "undefined" && errors.length > 0) { %>
    <div class="alert alert-danger shadow-sm rounded-3">
      <ul class="mb-0">
        <% errors.forEach((error) => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card form-card shadow-sm">
    <div class="card-body p-4 p-md-5">
      <form action="/quick-apply" method="POST">
        <div class="mb-3">
          <label for="fullName" class="form-label">Full Name</label>
          <input type="text" id="fullName" name="fullName" class="form-control form-control-lg" value="<%= quickApplyOldInput.fullName || '' %>" placeholder="Enter your full name" maxlength="80" required>
          <div class="form-text">Use your full legal name, 2 to 80 characters.</div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input type="email" id="email" name="email" class="form-control form-control-lg" value="<%= quickApplyOldInput.email || '' %>" placeholder="example@gmail.com" maxlength="120" required>
        </div>

        <div class="mb-3">
          <label for="phone" class="form-label">Phone Number</label>
          <input type="text" id="phone" name="phone" class="form-control form-control-lg" value="<%= quickApplyOldInput.phone || '' %>" placeholder="+256 701 234 567" maxlength="120" required>
          <div class="form-text">Use digits, spaces, +, or hyphens.</div>
        </div>

        <div class="mb-4">
          <label for="program" class="form-label">Selected Program</label>
          <select id="program" name="program" class="form-select form-select-lg" required>
            <option value="">-- Select Program --</option>
            <% (programs || []).forEach((program) => { %>
              <option value="<%= program.name %>" <%= quickApplySelectedProgram === program.name ? "selected" : "" %>><%= program.name %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100">Submit Application</button>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
