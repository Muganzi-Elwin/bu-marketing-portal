<!DOCTYPE html>
<html>
<head>
  <title>Work Program Application</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f7f9fc;
    }

    .work-application-container {
      max-width: 900px;
    }

    .header-card,
    .form-card {
      border: 0;
      border-radius: 1rem;
    }

    .header-card {
      background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<%
  const roles = [
    "Library Assistant",
    "Lab Technician Assistant",
    "Peer Tutor",
    "IT Support Assistant",
    "Campus Ambassador",
    "Administrative Assistant"
  ];
%>

<main class="container work-application-container py-5">
  <section class="card header-card shadow-sm text-center mb-4">
    <div class="card-body p-4 p-md-5">
      <h1 class="fw-bold mb-2">Work Program Application</h1>
      <p class="text-muted fs-5 mb-0">For Continuing Students Only</p>
    </div>
  </section>

  <div class="alert alert-info border-0 shadow-sm rounded-3 mb-4">
    Note: Work programs are only available to continuing students who are currently enrolled at the university.
    You must have a valid student registration number.
  </div>

  <section class="card form-card shadow-sm">
    <div class="card-body p-4 p-md-5">
      <form action="/work/apply" method="POST">
        <div class="mb-4">
          <label for="fullName" class="form-label fw-semibold fs-5">Full Name: <span class="text-muted">*</span></label>
          <input type="text" id="fullName" name="fullName" class="form-control form-control-lg" placeholder="Enter your full name" required>
        </div>

        <div class="mb-4">
          <label for="contact" class="form-label fw-semibold fs-5">Contact (Email/Phone): <span class="text-muted">*</span></label>
          <input type="text" id="contact" name="contact" class="form-control form-control-lg" placeholder="Email or phone number" required>
        </div>

        <div class="mb-4">
          <label for="registrationNumber" class="form-label fw-semibold fs-5">Student Registration Number: <span class="text-muted">*</span></label>
          <input type="text" id="registrationNumber" name="registrationNumber" class="form-control form-control-lg" placeholder="e.g., BU/2026/12345" required>
        </div>

        <div class="mb-4">
          <label for="selectedRole" class="form-label fw-semibold fs-5">Selected Role: <span class="text-muted">*</span></label>
          <select id="selectedRole" name="selectedRole" class="form-select form-select-lg" required>
            <option value="">-- Select a Role --</option>
            <% roles.forEach((role) => { %>
              <option value="<%= role %>" <%= selectedRole === role ? "selected" : "" %>><%= role %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100">Submit Work Application</button>
      </form>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
