<!DOCTYPE html>
<html>
<head>
  <title>B-U Marketing Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f7f9fc;
    }

    .page-container {
      max-width: 1140px;
    }

    .hero-section {
      background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
      border-radius: 1.5rem;
      margin-left: -1rem;
      margin-right: -1rem;
    }

    .hero-content {
      max-width: 980px;
    }

    .hero-img {
      width: 120%;
      max-height: 550px;
      object-fit: cover;
      border-radius: 1.2rem;
      box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.12);
      transition: transform 0.3s ease;
      cursor: pointer;
    }

    .hero-img:hover {
      transform: scale(1.04);
    }

    .program-visual {
      height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #edf4ff;
      color: #64748b;
      border-radius: 0.85rem;
      overflow: hidden;
    }

    .program-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 0.85rem;
    }

    .program-card {
      border: 0;
      border-radius: 1rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .program-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.12);
    }

    .featured-card {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .featured-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.12);
    }

    .featured-img-wrapper {
      overflow: hidden;
      border-radius: 0.75rem;
    }

    .featured-img {
      transition: transform 0.35s ease;
    }

    .featured-card:hover .featured-img {
      transform: scale(1.05);
    }

    .section-title {
      color: #102a43;
    }

    .cta-section {
      background: #eaf2ff;
      border-radius: 1.25rem;
    }

    .btn-primary {
      background-color: #0b5ed7;
      border-color: #0b5ed7;
    }

    .hero-apply-btn {
      box-shadow: 0 0.45rem 1rem rgba(11, 94, 215, 0.22);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .hero-apply-btn:hover {
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 0.75rem 1.5rem rgba(11, 94, 215, 0.3);
    }

    .hero-apply-btn:active {
      transform: translateY(0) scale(0.98);
      box-shadow: 0 0.35rem 0.8rem rgba(11, 94, 215, 0.22);
    }

    @media (max-width: 767.98px) {
      .hero-section {
        margin-left: 0;
        margin-right: 0;
      }

      .hero-img {
        max-height: 340px;
        border-radius: 1rem;
      }
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<main class="container page-container py-5">
  <% if (success === "feedback") { %>
    <div id="successAlert" class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 mb-4" role="alert">
      Thank you! Your feedback has been submitted successfully.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <section class="hero-section text-center p-4 p-md-5 mb-5 shadow-sm">
    <div class="hero-content mx-auto">
      <img src="/images/Hero-Image.jpeg" alt="Bugema University students" class="hero-img img-fluid mb-5" data-bs-toggle="modal" data-bs-target="#heroImagePreviewModal" data-img="/images/Hero-Image.jpeg" data-title="Apply to Bugema University">

      <h1 class="display-4 fw-bold mb-3">Apply to Bugema University</h1>
      <p class="fs-5 text-muted mb-4">Start your journey to excellence.</p>

      <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
        <a href="/programs" class="btn btn-outline-primary btn-lg px-4">Explore Programs</a>
        <a href="/admission" class="btn btn-primary btn-lg px-4 hero-apply-btn">Apply Now</a>
      </div>
    </div>
  </section>

  <section id="featuredPrograms" class="mb-5">
    <h2 class="section-title fw-bold pb-2 mb-4">Featured Programs</h2>

    <div class="row g-4">
      <% (featuredPrograms || []).forEach(program => { %>
        <% const programImage = featuredProgramImages && featuredProgramImages[program.name]; %>
        <div class="col-12 col-md-6">
          <div class="card program-card featured-card p-3 h-100 shadow-sm d-flex flex-column">
            <div class="program-visual featured-img-wrapper mb-3">
              <% if (programImage) { %>
                <img src="<%= programImage %>" alt="<%= program.name %>" class="program-img featured-img img-fluid">
              <% } else { %>
                <span>Program Image</span>
              <% } %>
            </div>
            <div class="card-body p-2 d-flex flex-column flex-grow-1">
              <h3 class="fs-4 fw-bold mb-2"><%= program.name %></h3>
              <p class="text-muted small mb-4"><%= program.school %></p>
              <a href="/programs/<%= program._id %>" class="btn btn-outline-primary w-100 mt-auto">View Details</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="cta-section text-center p-4 p-md-5 shadow-sm">
    <h2 class="fs-3 fw-bold mb-3">Ready to Start Your Application?</h2>
    <p class="text-muted mb-4">Begin your application today and secure your future.</p>
    <a href="/admission" class="btn btn-primary btn-lg px-5">Apply Now</a>
  </section>
</main>

<div class="modal fade" id="heroImagePreviewModal" tabindex="-1" aria-labelledby="heroImagePreviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 overflow-hidden">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="heroImagePreviewModalLabel">Image Preview</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center bg-light">
        <img id="heroImagePreviewModalImg" src="" alt="" class="img-fluid rounded shadow-sm">
        <p id="heroImagePreviewModalCaption" class="text-muted mt-3 mb-0"></p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const successAlert = document.getElementById("successAlert");

  if (successAlert) {
    setTimeout(() => {
      const alert = bootstrap.Alert.getOrCreateInstance(successAlert);
      alert.close();
    }, 5000);
  }

  const heroImagePreviewModal = document.getElementById("heroImagePreviewModal");

  if (heroImagePreviewModal) {
    heroImagePreviewModal.addEventListener("show.bs.modal", (event) => {
      const trigger = event.relatedTarget;
      const imageSrc = trigger.getAttribute("data-img");
      const imageTitle = trigger.getAttribute("data-title");
      const modalTitle = document.getElementById("heroImagePreviewModalLabel");
      const modalImage = document.getElementById("heroImagePreviewModalImg");
      const modalCaption = document.getElementById("heroImagePreviewModalCaption");

      modalTitle.textContent = imageTitle || "Image Preview";
      modalImage.src = imageSrc || "";
      modalImage.alt = imageTitle || "Hero image";
      modalCaption.textContent = imageTitle || "";
    });
  }
</script>
</body>
</html>
