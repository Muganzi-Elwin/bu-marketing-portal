<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #eef2f6;
      color: #263238;
      font-family: Arial, Helvetica, sans-serif;
    }

    .admin-layout {
      min-height: 100vh;
      display: flex;
    }

    .admin-sidebar {
      width: 280px;
      min-height: 100vh;
      background: linear-gradient(180deg, #003366 0%, #00264d 100%);
      color: #fff;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      box-shadow: 0.5rem 0 1.5rem rgba(15, 23, 42, 0.08);
    }

    .admin-sidebar-header {
      border-bottom: 1px solid rgba(255, 255, 255, 0.16);
      padding-bottom: 1rem;
      margin-bottom: 1.25rem;
    }

    .admin-nav {
      display: grid;
      gap: 0.45rem;
    }

    .admin-nav-link {
      color: #fff;
      text-decoration: none;
      display: block;
      padding: 0.8rem 0.95rem;
      border-radius: 0.75rem;
      font-weight: 600;
      transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .admin-nav-link:hover {
      background: rgba(255, 255, 255, 0.12);
      color: #ffcc00;
      transform: translateX(2px);
    }

    .admin-nav-link.active {
      background: #ffcc00;
      color: #003366;
    }

    .admin-sidebar-footer {
      margin-top: auto;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(255, 255, 255, 0.16);
    }

    .admin-back-link {
      background: rgba(255, 255, 255, 0.1);
    }

    .admin-main {
      flex: 1;
      padding: 2rem;
    }

    .summary-card {
      border: 0;
      border-radius: 1rem;
      box-shadow: 0 0.5rem 1.25rem rgba(15, 23, 42, 0.08);
    }

    .summary-label {
      color: #607080;
      font-weight: 600;
    }

    .summary-value {
      color: #003366;
      font-size: 2rem;
      font-weight: 800;
    }

    @media (max-width: 991.98px) {
      .admin-layout {
        flex-direction: column;
      }

      .admin-sidebar {
        width: 100%;
        min-height: auto;
      }

      .admin-main {
        padding: 1.25rem;
      }
    }
  </style>
</head>
<body>
  <% const dashboardSummary = typeof summary !== "undefined" ? summary : {}; %>

  <div class="admin-layout">
    <%- include('../partials/adminSidebar', { activeAdminPage: 'dashboard' }) %>

    <main class="admin-main">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
          <h1 class="fw-bold mb-1">Dashboard Overview</h1>
          <p class="text-muted mb-0">Monitor portal activity and admin tasks from one place.</p>
        </div>
      </div>

      <% if (typeof errorMessage !== "undefined") { %>
        <div class="alert alert-danger shadow-sm rounded-3 mb-4"><%= errorMessage %></div>
      <% } %>

      <div class="row g-4">
        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Total Applications</p>
              <div class="summary-value"><%= dashboardSummary.totalApplications || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Admissions</p>
              <div class="summary-value"><%= dashboardSummary.totalAdmissions || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Scholarships</p>
              <div class="summary-value"><%= dashboardSummary.totalScholarships || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Bursaries</p>
              <div class="summary-value"><%= dashboardSummary.totalBursaries || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Work Applications</p>
              <div class="summary-value"><%= dashboardSummary.totalWorkApplications || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Feedback Responses</p>
              <div class="summary-value"><%= dashboardSummary.totalFeedback || 0 %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Top Marketing Source</p>
              <div class="summary-value fs-4"><%= dashboardSummary.topMarketingSource || "No data" %></div>
            </div>
          </section>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <section class="card summary-card h-100">
            <div class="card-body p-4">
              <p class="summary-label mb-2">Average Rating</p>
              <div class="summary-value"><%= dashboardSummary.averageRating || 0 %></div>
            </div>
          </section>
        </div>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
