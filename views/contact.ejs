<!DOCTYPE html>
<html>
<head>
  <title>Contact &amp; About</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    body {
      background: #f7f9fc;
    }

    .contact-container {
      max-width: 1140px;
    }

    .hero-card,
    .info-card,
    .location-card {
      border: 0;
      border-radius: 1rem;
    }

    .hero-card {
      background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
    }

    .icon-badge {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 50%;
      background: linear-gradient(135deg, #003366, #0055aa);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      box-shadow: 0 0.45rem 1rem rgba(0, 51, 102, 0.18);
      flex: 0 0 auto;
    }

    .fact-row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid #e2e8f0;
    }

    .fact-row:last-child {
      border-bottom: 0;
    }

    .social-link {
      text-decoration: none;
    }

    .social-icon-link {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #d8e2ef;
      background: #fff;
      color: #0055aa;
      font-size: 1.25rem;
      box-shadow: 0 0.35rem 0.9rem rgba(15, 23, 42, 0.08);
      transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .social-icon-link:hover {
      transform: translateY(-2px);
      background: #0055aa;
      border-color: #0055aa;
      color: #fff;
    }

    .social-icon-link.facebook {
      background: #1877f2;
      border-color: #1877f2;
      color: #fff;
    }

    .social-icon-link.youtube {
      background: #ff0000;
      border-color: #ff0000;
      color: #fff;
    }

    .social-icon-link.tiktok {
      background: #111;
      border-color: #111;
      color: #fff;
    }

    .social-icon-link.twitter {
      background: #000;
      border-color: #000;
      color: #fff;
    }

    .social-icon-link.linkedin {
      background: #0a66c2;
      border-color: #0a66c2;
      color: #fff;
    }

    .social-icon-link.facebook:hover,
    .social-icon-link.youtube:hover,
    .social-icon-link.tiktok:hover,
    .social-icon-link.twitter:hover,
    .social-icon-link.linkedin:hover {
      filter: brightness(0.92);
      color: #fff;
    }

    .whatsapp-button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      box-shadow: 0 0.35rem 0.9rem rgba(25, 135, 84, 0.18);
    }

    .location-card {
      background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
      overflow: hidden;
    }

    .location-icon {
      width: 4rem;
      height: 4rem;
      border-radius: 1rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #003366;
      color: #fff;
      font-size: 1.75rem;
      box-shadow: 0 0.6rem 1.2rem rgba(0, 51, 102, 0.18);
    }
  </style>
</head>
<body>

<%- include('partials/navbar') %>

<main class="container contact-container py-5">
  <section class="card hero-card shadow-sm text-center mb-5">
    <div class="card-body p-4 p-md-5">
      <h1 class="fw-bold mb-2">Contact &amp; About</h1>
      <p class="text-muted fs-5 mb-0">Get in Touch with Bugema University</p>
    </div>
  </section>

  <div class="row g-4">
    <div class="col-12 col-lg-6">
      <section class="card info-card shadow-sm h-100">
        <div class="card-body p-4">
          <h2 class="fw-bold mb-4">Contact Information</h2>

          <div class="d-grid gap-4">
            <div>
              <div class="d-flex align-items-start gap-3">
                <span class="icon-badge"><i class="bi bi-geo-alt-fill"></i></span>
                <div>
                  <h3 class="h5 fw-bold mb-2">Postal Address</h3>
                  <p class="text-muted mb-1">P.O. Box 6529, Kampala, Uganda</p>
                  <p class="text-muted mb-0">Bugema, Luweero, Uganda</p>
                </div>
              </div>
            </div>

            <div>
              <div class="d-flex align-items-start gap-3">
                <span class="icon-badge"><i class="bi bi-telephone-fill"></i></span>
                <div>
                  <h3 class="h5 fw-bold mb-2">Phone</h3>
                  <p class="mb-1"><i class="bi bi-telephone me-2 text-primary"></i><a href="tel:+256312351400">+256 312 351 400</a></p>
                  <p class="mb-3"><i class="bi bi-telephone me-2 text-primary"></i><a href="tel:+256702940003">+256 702 940 003</a></p>
                  <div class="d-flex flex-column flex-sm-row gap-2">
                    <a href="https://wa.me/256702940003" target="_blank" rel="noopener" class="btn btn-success btn-sm whatsapp-button">
                      <i class="bi bi-whatsapp"></i>
                      <span>WhatsApp +256 702 940 003</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <div>
              <div class="d-flex align-items-start gap-3">
                <span class="icon-badge"><i class="bi bi-envelope-fill"></i></span>
                <div>
                  <h3 class="h5 fw-bold mb-2">Email</h3>
                  <p class="mb-1"><i class="bi bi-envelope me-2 text-primary"></i><a href="mailto:marketing@bugemauniv.ac.ug">marketing@bugemauniv.ac.ug</a></p>
                  <p class="mb-0"><i class="bi bi-envelope me-2 text-primary"></i><a href="mailto:info@bugemauniv.ac.ug">info@bugemauniv.ac.ug</a></p>
                </div>
              </div>
            </div>

            <div>
              <div class="d-flex align-items-start gap-3">
                <span class="icon-badge"><i class="bi bi-clock-fill"></i></span>
                <div>
                  <h3 class="h5 fw-bold mb-2">Office Hours</h3>
                  <p class="text-muted mb-1">Monday - Thursday: 8:00 AM - 4:00 PM</p>
                  <p class="text-muted mb-1">Friday - 8:00 AM - 12:00 PM</p>
                  <p class="text-muted mb-1">Saturday: Sabbath Day</p>
                  <p class="text-muted mb-0">Sunday: Closed</p>
                </div>
              </div>
            </div>

            <p>
              
            </p>
            <div>
              <h3 class="h5 fw-bold mb-3">Social Media</h3>
              <div class="d-flex flex-wrap gap-3">
                <a class="social-icon-link facebook" href="https://www.facebook.com/share/14aV2tDSDVA/" target="_blank" rel="noopener" aria-label="Facebook">
                  <i class="bi bi-facebook"></i>
                </a>
                <a class="social-icon-link youtube" href="https://www.youtube.com/@bugemauniversity3502" target="_blank" rel="noopener" aria-label="YouTube">
                  <i class="bi bi-youtube"></i>
                </a>
                <a class="social-icon-link tiktok" href="https://www.tiktok.com/@bugemauniv" target="_blank" rel="noopener" aria-label="TikTok">
                  <i class="bi bi-tiktok"></i>
                </a>
                <a class="social-icon-link twitter" href="https://x.com/UnivBugema" target="_blank" rel="noopener" aria-label="Twitter/X">
                  <i class="bi bi-twitter-x"></i>
                </a>
              
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="col-12 col-lg-6">
      <section class="card info-card shadow-sm h-100">
        <div class="card-body p-4">
          <h2 class="fw-bold mb-4">About Bugema University</h2>

          <div class="d-grid gap-4">
            <div>
              <h3 class="h5 fw-bold mb-2">Mission</h3>
              <p class="text-muted mb-0">Bugema University provides holistic Christian education for productive service.</p>
            </div>

            <div>
              <h3 class="h5 fw-bold mb-2">Vision/Motto</h3>
              <p class="text-muted mb-0">Excellence in Service.</p>
            </div>

            <div>
              <h3 class="h5 fw-bold mb-2">Educational Philosophy</h3>
              <p class="text-muted mb-0">Balanced development in physical, mental, and spiritual growth.</p>
            </div>

            <div>
              <h3 class="h5 fw-bold mb-2">Core Values</h3>
              <ul class="text-muted mb-0">
                <li>Academic excellence</li>
                <li>Integrity</li>
                <li>Christian service</li>
                <li>Innovation</li>
                <li>Community service</li>
              </ul>
            </div>

            <div>
              <h3 class="h5 fw-bold mb-3">Quick Facts</h3>
              <div class="bg-light rounded-3 px-3">
                <div class="fact-row">
                  <span class="text-muted">Founded</span>
                  <span class="fw-semibold">1948</span>
                </div>
                <div class="fact-row">
                  <span class="text-muted">Location</span>
                  <span class="fw-semibold text-end">Bugema, Luweero, Uganda</span>
                </div>
                <div class="fact-row">
                  <span class="text-muted">Type</span>
                  <span class="fw-semibold">Christian university</span>
                </div>
                <div class="fact-row">
                  <span class="text-muted">Motto</span>
                  <span class="fw-semibold">Excellence in Service</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <section class="card location-card shadow-sm mt-4">
    <div class="card-body p-4 p-md-5">
      <div class="row g-4 align-items-center">
        <div class="col-12 col-lg-8">
          <div class="d-flex align-items-center gap-3">
            <span class="location-icon"><i class="bi bi-map-fill"></i></span>
            <div>
              <h2 class="fw-bold mb-2">Click to view Campus Location</h2>
              <p class="text-muted mb-0">Open Bugema University Main Campus in Google Maps.</p>
            </div>
          </div>
        </div>
        <div class="col-12 col-lg-4 text-lg-end">
          <a href="https://www.google.com/maps/search/?api=1&query=Bugema+University+Main+Campus+Luweero+Uganda" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
            Campus Location
          </a>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
